# =============================================================================
# DNS Cluster - environment template
# =============================================================================
# This file is used by ./scripts/node-init.sh to generate a node-specific .env.
# Across all nodes you use the same secrets; only the node identity differs.
# =============================================================================

# ----- Node identity (different on EACH node) --------------------------------
# Must be included in CLUSTER_NODES
NODE_NAME=ns1

# ----- Cluster topology (IDENTICAL on ALL nodes) -----------------------------
CLUSTER_NAME=dnscluster

# Domain under which node FQDNs resolve (e.g. cluster.example.net)
# Per node this setup expects: <NODE_NAME>.<NODE_FQDN_DOMAIN>
NODE_FQDN_DOMAIN=cluster.as209800.net

# Which nodes are part of the cluster (comma-separated, freely extensible)
CLUSTER_NODES=ns1,ns2,ns3,ns4

# Per-node attributes (schema: NODE_<NODE>_<ATTR>, node in UPPERCASE, e.g. NODE_NS1_WG_IP)
# Public IPs (informational; WireGuard uses FQDN endpoints + DNS, NOT these values)
NODE_NS1_PUBLIC_IPV4=
NODE_NS1_PUBLIC_IPV6=
NODE_NS2_PUBLIC_IPV4=
NODE_NS2_PUBLIC_IPV6=
NODE_NS3_PUBLIC_IPV4=
NODE_NS3_PUBLIC_IPV6=
NODE_NS4_PUBLIC_IPV4=
NODE_NS4_PUBLIC_IPV6=

# WireGuard mesh IPs (internal, never change)
WG_SUBNET=10.100.0.0/24
# Patroni pg_hba: Docker-Compose network "cluster" (see docker-compose.yml → networks.cluster.ipam)
CLUSTER_BRIDGE_SUBNET=172.28.0.0/24
NODE_NS1_WG_IP=10.100.0.1
NODE_NS2_WG_IP=10.100.0.2
NODE_NS3_WG_IP=10.100.0.3
NODE_NS4_WG_IP=10.100.0.4

# Per node: preferred address family for WireGuard endpoint resolution. auto|v4|v6
# - auto: prefer v6 if AAAA exists, else v4
# - v4:   only A records
# - v6:   only AAAA records
NODE_NS1_WG_AF=auto
NODE_NS2_WG_AF=auto
NODE_NS3_WG_AF=auto
NODE_NS4_WG_AF=auto

# Optional site label (monitoring labels only; arbitrary)
NODE_NS1_SITE=nl
NODE_NS2_SITE=fr
NODE_NS3_SITE=de
NODE_NS4_SITE=ams

# Patroni failover policy (per node; node-init.sh copies these into the computed section)
# Defaults: nofailover=false, failover_priority=50 (if not set)
PATRONI_FAILOVER_PRIORITY_NS1=100
PATRONI_FAILOVER_PRIORITY_NS2=50
PATRONI_FAILOVER_PRIORITY_NS3=30
PATRONI_FAILOVER_PRIORITY_NS4=25
PATRONI_NOFAILOVER_NS1=false
PATRONI_NOFAILOVER_NS2=false
PATRONI_NOFAILOVER_NS3=false
PATRONI_NOFAILOVER_NS4=false

# etcd initial cluster (set to 'new' for bootstrap, then 'existing')
# Ideally generated by the first-use installer from CLUSTER_NODES + NODE_*_WG_IP
ETCD_INITIAL_CLUSTER=ns1=http://10.100.0.1:2380,ns2=http://10.100.0.2:2380,ns3=http://10.100.0.3:2380,ns4=http://10.100.0.4:2380
ETCD_INITIAL_CLUSTER_STATE=new
ETCD_INITIAL_CLUSTER_TOKEN=dnscluster-etcd-token

# ----- Inter-node sync (for helper scripts) ----------------------------------
# Public hostnames (no port, FQDN); used by ./scripts/cluster-sync.sh
# for SSH-based operations. Default = based on NODE_FQDN_DOMAIN.
SYNC_SSH_USER=ns-cluster-sync
SYNC_SSH_PORT=22

# ----- Credentials (IDENTICAL on all nodes) ----------------------------------
# Generate with: openssl rand -base64 32
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_superuser
POSTGRES_REPLICATION_PASSWORD=CHANGE_ME_replication
POSTGRES_REWIND_PASSWORD=CHANGE_ME_rewind
PATRONI_REST_PASSWORD=CHANGE_ME_patroni_api

PDNS_DB_PASSWORD=CHANGE_ME_pdns
PDNS_API_KEY=CHANGE_ME_pdns_api_key
PDNS_ADMIN_SECRET_KEY=CHANGE_ME_admin_session_key
PDNS_ADMIN_SALT=CHANGE_ME_admin_salt

GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana

# ----- Let's Encrypt (Caddy reverse proxy for Grafana + PowerDNS-Admin) ------
# Email for ACME certificate requests (expiry warnings).
ACME_EMAIL=admin@example.com

# Optional: Let's Encrypt staging for testing (avoid rate limits).
# Leave empty for production. For testing:
#   LE_ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
LE_ACME_CA=

# ----- Computed (do NOT set manually; filled by node-init.sh) ----------------
# NODE_WG_IP, NODE_PUBLIC_IPV4, NODE_PUBLIC_IPV6, NODE_FQDN,
# PATRONI_FAILOVER_PRIORITY, PATRONI_NOFAILOVER
